# =============================================================================
# Inventory App — Production Environment Variables
# =============================================================================
# Copy this file to .env at the project root and fill in your values.
#   cp .env.example .env
#
# Docker Compose reads .env automatically for ${VAR} substitution.
# Dokploy: paste these vars in the Environment Variables UI.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend API (service: api)
# ---------------------------------------------------------------------------
APP_NAME=Inventory API
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# PostgreSQL connection string (Supabase).
# Get it from: Supabase Dashboard > Project Settings > Database > URI
# Must use the asyncpg driver: postgresql+asyncpg://...
DATABASE_URL=postgresql+asyncpg://postgres:password@aws-0-region.pooler.supabase.com:5432/postgres

# Supabase — used for authentication (JWT validation) and service-role ops.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudinary — used for photo uploads.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT secret — must match what Supabase uses to sign JWTs.
# In Supabase Dashboard: Project Settings > API > JWT Secret
JWT_SECRET=your-jwt-secret-min-32-chars-long

# Public-facing URL of the web app (used for OAuth redirect_to).
FRONTEND_URL=https://your-domain.com

# Comma-separated list of allowed CORS origins.
# For production: https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Workers for gunicorn (default: 4).
WORKERS=4

# Sentry DSN (optional — leave empty to disable).
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Web App (service: web)
# ---------------------------------------------------------------------------

# Internal URL the web container uses to reach the API container.
BACKEND_API_URL=http://api:8001

# Public-facing URL of the web app (used for meta tags, etc.).
APP_URL=https://your-domain.com
