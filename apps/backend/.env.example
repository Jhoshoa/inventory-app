# ─── App ──────────────────────────────────────────
APP_NAME=Inventory API
APP_VERSION=0.1.0

# Cambiar a "production" en produccion (activa validaciones: no SQLite, no placeholders, DEBUG=false)
ENVIRONMENT=local

# DEBUG=true obliga a false cuando ENVIRONMENT=production
DEBUG=true

LOG_LEVEL=INFO
# Numero de workers gunicorn (default: CPU*2+1). Solo aplica en entrypoint.sh
# WORKERS=4
# Puerto del backend (default: 8001). Solo aplica en entrypoint.sh
# PORT=8001

# URL publica del frontend (usada para redirects de OAuth)
FRONTEND_URL=http://localhost:3000

# Origenes CORS permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Mostrar detalles de error al cliente. Default: =DEBUG (true en dev, false en prod)
# En produccion forzarlo a false: EXPOSE_ERROR_DETAILS=false
EXPOSE_ERROR_DETAILS=

# ─── Base de Datos ───────────────────────────────
# Desarrollo: SQLite (no requiere servidor externo)
# DATABASE_URL=sqlite+aiosqlite:///./inventory_dev.db
# Desarrollo: PostgreSQL local
# DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory_dev
# Produccion: Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.pooler.supabase.com:5432/postgres

# ─── Supabase Auth ───────────────────────────────
# Obligatorias en produccion. Obtener de: Project Settings > API
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<tu-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>

# ─── Cloudinary (imagenes) ──────────────────────
CLOUDINARY_CLOUD_NAME=<tu-cloud-name>
CLOUDINARY_API_KEY=<tu-api-key>
CLOUDINARY_API_SECRET=<tu-api-secret>

# ─── Seguridad ───────────────────────────────────
# Debe coincidir con: Supabase Dashboard > Project Settings > API > JWT Secret
# Generar con: openssl rand -hex 32
JWT_SECRET=<tu-jwt-secret>

# ─── Monitoreo ──────────────────────────────────
SENTRY_DSN=
