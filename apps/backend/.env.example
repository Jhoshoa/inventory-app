# ─── App ──────────────────────────────────────────
APP_NAME=Inventory API
APP_VERSION=0.1.0

# Cambiar a "production" en produccion (activa validaciones: no SQLite, no placeholders, DEBUG=false)
ENVIRONMENT=local

# DEBUG=true obliga a false cuando ENVIRONMENT=production
DEBUG=true

LOG_LEVEL=INFO
# Numero de workers gunicorn (default: CPU*2+1). Solo aplica en entrypoint.sh
# WORKERS=4
# Puerto del backend (default: 8000). Solo aplica en entrypoint.sh
# PORT=8000

# ─── Base de Datos ───────────────────────────────
# Desarrollo: SQLite (no requiere servidor externo)
# DATABASE_URL=sqlite+aiosqlite:///./inventory_dev.db
# Produccion: PostgreSQL (Supabase o VPS)
DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory_dev

# ─── Supabase Auth ───────────────────────────────
# Obligatorias en produccion. Obtener de: Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Cloudinary (imagenes) ──────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Seguridad ───────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=your-jwt-secret

# ─── Monitoreo ──────────────────────────────────
SENTRY_DSN=

# ─── CORS ───────────────────────────────────────
# Produccion: https://tudominio.com (no usar *)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Mostrar detalles de error al cliente. Default: =DEBUG (true en dev, false en prod)
# En produccion forzarlo a false: EXPOSE_ERROR_DETAILS=false
EXPOSE_ERROR_DETAILS=
